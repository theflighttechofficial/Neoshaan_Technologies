<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Online Event Registration (v6)</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial; margin: 24px; }
    form { max-width: 520px; }
    fieldset { margin-bottom: 16px; padding: 16px; }
    input[type="text"], input[type="email"], input[type="tel"] {
      width: 100%; padding: 10px; margin-top: 6px; margin-bottom: 12px;
      box-sizing: border-box; border: 1px solid #ccc; border-radius: 6px;
    }
    input[type="submit"] { padding: 10px 14px; border: none; border-radius: 6px; cursor: pointer; }
  </style>
</head>
<body>
  <h1>Online Event Registration (v6)</h1>

  <form action="#" method="post">
    <fieldset>
      <legend>Personal Details</legend>

      <!-- Full Name -->
      <input type="text" name="fullName" aria-label="Full Name"
             placeholder="Full Name" required
             pattern="^[A-Za-z\s]{2,50}$"
             title="Full name should contain only letters and spaces (2–50 characters)."
             minlength="2" maxlength="50" />

      <!-- Email -->
      <input type="email" name="email" aria-label="Email Address"
             placeholder="Email Address" required
             maxlength="100"
             title="Enter a valid email address (e.g., user@example.com)" />

      <!-- Phone -->
      <input type="tel" name="phone" aria-label="Phone Number"
             placeholder="Phone Number (e.g., +91 9876543210)"
             pattern="^(\+?\d{1,3}[- ]?)?\d{10}$"
             title="Enter a valid 10-digit number, optionally with country code (e.g., +91 9876543210)."
             minlength="10" maxlength="15" required />
    </fieldset>

    <fieldset>
      <legend>Event Details</legend>

      <!-- Event Name -->
      <input type="text" name="eventName" aria-label="Event Name"
             placeholder="Event Name" required
             minlength="3" maxlength="60"
             pattern="^[A-Za-z0-9\s]{3,60}$"
             title="Event name should be 3–60 characters (letters, numbers, spaces allowed)." />

      <!-- Organization -->
      <input type="text" name="organization" aria-label="Organization"
             placeholder="Organization (optional)"
             minlength="2" maxlength="80"
             pattern="^[A-Za-z0-9\s]{2,80}$"
             title="Organization name should be 2–80 characters (letters, numbers, spaces allowed)." />

      <!-- City -->
      <input type="text" name="city" aria-label="City"
             placeholder="City (optional)"
             minlength="2" maxlength="50"
             pattern="^[A-Za-z\s]{2,50}$"
             title="City should only contain letters (2–50 characters)." />
    </fieldset>

    <input type="submit" value="Register" />
  </form>
</body>
</html>
